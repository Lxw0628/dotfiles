 } else if (operational === \"+\") {\n        number2 = number1 * (parseFloat(number2) / 100);\n        lable.innerHTML = number2;\n      } else {\n        number2 = parseFloat(number2) / 100;\n        lable.innerHTML = number2;\n      }\n      break;\n    case \"+\":\n      operational = \"+\";\n      break;\n    case \"-\":\n      operational = \"-\";\n      break;\n    case \"×\":\n      operational = \"×\";\n      break;\n    case \"÷\":\n      operational = \"÷\";\n      break;\n    case \"=\":\n      // 先将两次数字转型\n      var num1 = parseFloat(number1);\n      var num2 = parseFloat(number2);\n      switch (operational) {\n        case \"+\":\n          lable.innerHTML = num1 + num2;\n          break;\n        case \"-\":\n          lable.innerHTML = num1 - num2;\n          break;\n        case \"×\":\n          lable.innerHTML = num1 * num2;\n          break;\n        case \"÷\":\n          if (number2 === 0) {\n            // lable.innerHTML = \"除数不能为0\";\n            lable.innerHTML = \"NaN\";\n          } else {\n            lable.innerHTML = nu1 / num2;\n          }\n          break;\n        default:\n          break;\n      }\n      break;\n    default:\n      if (operational == \"\") {\n        number1 += txt;\n        lable.innerHTML = number1;\n      } else {\n        number2 += txt;\n        lable.innerHTML = number2;\n      }\n      break;\n  }\n};" clean_function:"btns[i].onclick = function () {\n  var txt = this.innerHTML;\n  switch (txt) {\n    case \"AC\":\n      // 清除为0\n      number1 = \"\";\n      number2 = \"\";\n      operational = \"\";\n      lable.innerHTML = \"0\";\n      break;\n    case \"+/-\":\n      if (operational == \"\") {\n        lable.innerHTML = \"-\" + number1;\n        number1 = number1 * -1;\n      } else {\n        lable.innerHTML = \"-\" + number2;\n        number2 = number2 * -1;\n      }\n      break;\n    case \"%\":\n      // 啥乱苹果\n      // A% + B% = A% + A% * B%\n      if (operational === \"\") {\n        number1 = parseFloat(number1) / 100;\n        lable.innerHTML = number1;\n      } else if (operational === \"+\") {\n        number2 = number1 * (parseFloat(number2) / 100);\n        lable.innerHTML = number2;\n      } else {\n        number2 = parseFloat(number2) / 100;\n        lable.innerHTML = number2;\n      }\n      break;\n    case \"+\":\n      operational = \"+\";\n      break;\n    case \"-\":\n      operational = \"-\";\n      break;\n    case \"×\":\n      operational = \"×\";\n      break;\n    case \"÷\":\n      operational = \"÷\";\n      break;\n    case \"=\":\n      // 先将两次数字转型\n      var num1 = parseFloat(number1);\n      var num2 = parseFloat(number2);\n      switch (operational) {\n        case \"+\":\n          lable.innerHTML = num1 + num2;\n          break;\n        case \"-\":\n          lable.innerHTML = num1 - num2;\n          break;\n        case \"×\":\n          lable.innerHTML = num1 * num2;\n          break;\n        case \"÷\":\n          if (number2 === 0) {\n            // lable.innerHTML = \"除数不能为0\";\n            lable.innerHTML = \"NaN\";\n          } else {\n            lable.innerHTML = nu1 / num2;\n          }\n          break;\n        default:\n          break;\n      }\n      break;\n    default:\n      if (operational == \"\") {\n        number1 += txt;\n        lable.innerHTML = number1;\n      } else {\n        number2 += txt;\n        lable.innerHTML = number2;\n      }\n      break;\n  }\n};" docstring:"console.log(btns[i]);" node_name:"onclick" params:"()" definition_line:17 start_line:16 end_line:98 start_col:2 end_col:4 leading_whitespace:"  " language:LANGUAGE_JAVASCRIPT} language:LANGUAGE_JAVASCRIPT file_path:"/home/lxw/Desktop/千锋教育/Java/LOL-html/js/calc.js"}}}} messages:{message:{message_id:"status-7fc82a7d-9cf3-4cb3-a1a6-cfd238ac2a82" source:CHAT_MESSAGE_SOURCE_SYSTEM timestamp:{seconds:1701259101 nanos:363848646} conversation_id:"5OVgQKDNDtFsYmZtWidbkmIyxDapsuwu" status:{context_relevancy:{}}} stream_id:"2326123d-f95a-434