671109218} conversation_id:"m1OyfReGE3nYdIYR5fKX9OOz7JKgTk89" action:{generic:{text:"This code snippet is an event handler for a calculator. When a button is clicked, the function inside the event handler is executed. It performs different operations based on the text value of the button that was clicked. For example, if the button text is \"AC\", it clears the calculator display. If the button text is a number or an arithmetic operator, it appends the text to the appropriate number variable. Finally, if the button text is \"=\", it performs the corresponding arithmetic operation and displays the result on the calculator."} num_tokens:104}} stream_id:"729c60ab-77da-4766-b8e7-58f8c0908d81"} messages:{message:{message_id:"bot-93e91781-70c3-403e-aff5-f5e082ace332" source:CHAT_MESSAGE_SOURCE_SYSTEM timestamp:{seconds:1701306761 nanos:797778775} conversation_id:"RH5DszDYY5aGyCdrW44FWJpY3OvTwCwt" action:{edit:{file_path:"/home/lxw/Desktop/千锋教育/Java/LOL-html/js/calc.js" diff:{start_line:18 end_line:18 unified_diff:{lines:{text:"  /**" type:UNIFIED_DIFF_LINE_TYPE_INSERT} lines:{text:"   * Handle the click event of the buttons." type:UNIFIED_DIFF_LINE_TYPE_INSERT} lines:{text:"   *" type:UNIFIED_DIFF_LINE_TYPE_INSERT} lines:{text:"   * @param {string} txt - The innerHTML of the clicked button." type:UNIFIED_DIFF_LINE_TYPE_INSERT} lines:{text:"   * @return {void}" type:UNIFIED_DIFF_LINE_TYPE_INSERT} lines:{text:"   */" type:UNIFIED_DIFF_LINE_TYPE_INSERT}} from_language:LANGUAGE_JAVASCRIPT to_language:LANGUAGE_JAVASCRIPT} language:LANGUAGE_JAVASCRIPT} num_tokens:44}} stream_id:"60847c96-f93c-4382-898c-f47636976926"} messages:{message:{message_id:"user-97473927-fa74-4d9a-a99e-11cba7cba438" source:CHAT_MESSAGE_SOURCE_USER timestamp:{seconds:1701306782 nanos:183648776} conversation_id:"QyKBCjH2REam7Xw9xGuKJzzcP2sNPu7W" intent:{function_refactor:{function_info:{raw_source:"btns[i].onclick = function () {\n  var txt = this.innerHTML;\n  console.log(this.innerHTML);\n  // console.log(txt);\n  // console.log(typeof txt);\n  switch (txt) {\n    case \"AC\": {\n      // 清除为0\n      number1 = \"\";\n      number2 = \"\";\n      operational = \"\";\n      lable.innerHTML = \"0\";\n      break;\n    }\n    case \"+/-\": {\n      if (operational === \"\") {\n        lable.innerHTML = \"-\" + number1;\n        number1 = number1 * -1;\n      } else {\n        lable.innerHTML = \"-\" + number2;\n        number2 = number2 * -1;\n      }\n      break;\n    }\n    case \"%\": {\n      // 啥乱苹果\n      // A% + B% = A% + A% * B%\n      if (operational === \"\") {\n        number1 = number1 / 100;\n        lable.innerHTML = number1;\n      } else if (operational === \"+\" || operational === \"-\") {\n        number2 = number1 * (number2 / 100);\n        lable.innerHTML = number2;\n      } else {\n        number2 = number2 / 100;\n        lable.innerHTML = number2;\n      }\n      break;\n    }\n    case \"+\": {\n      operational = \"+\";\n      break;\n    }\n    case \"-\": {\n      operational = \"-\";\n      break;\n    }\n    case \"x\": {\n      operational = \"x\";\n      break;\n    }\n    case \"÷\": {\n      operational = \"÷\";\n      break;\n    }\n    case \"=\": {\n      // 先将两次数字转型\n      var num1 = parseFloat(number1);\n      var num2 = parseFloat(number2);\n      switch (operational) {\n        case \"+\":\n          lable.innerHTML = num1 + num2;\n          break;\n        case \"-\":\n          lable.innerHTML = num1 - num2;\n          break;\n        case \"x\":\n          lable.innerHTML = num1 * num2;\n          break;\n        case \"÷\":\n          if (num2 === 0) {\n            lable.innerHTML = \"错误\";\n          } else {\n            lable.innerHTML = num1 / num2;\n          }\n          break;\n        default:\n          break;\n      }\n      break;\n    }\n    default: {\n      if (operational === \"\") {\n        number1 += txt;\n        lable.innerHTML = number1;\n      } else {\n        number2 += txt;\n        lable.innerHTML = number2;\n      }\n      break;\n    }\n  }\n};" clean_function:"btns[i].onclick = function () {\n  var txt = this.innerHTML;\n  console.log(this.innerHTML);\n  // console.log(txt);\n  // console.log(typeof txt);\n  switch (txt) {\n    case \"AC\": {\n      // 清除为0\n      number1 = \"\";\n      number2 = \"\";\n      operational = \"\";\n      lable.innerHTML = \"0\";\n      break;\n    }\n    case \"+/-\": {\n      if (operational === \"\") {\n        lable.innerHTML = \"-\" + number1;\n        number1 = number1 * -1;\n      } else {\n        lable.innerHTML = \"-\" + number2;\n        number2 = number2 * -1;\n      }\n      break;\n    }\n    case \"%\": {\n      // 啥乱苹果\n      // A% + B% = A% + A% * B%\n      if (operational === \"\") {\n        number1 = number1 / 100;\n        lable.innerHTML = number1;\n      } else if (operational === \"+\" || operational === \"-\") {\n        number2 = number1 * (number2 / 100);\n        lable.innerHTML = number2;\n      } else {\n        number2 = number2 / 100;\n        lable.innerHTML = number2;\n      }\n      break;\n    }\n    case \"+\": {\n      operational = \"+\";\n      break;\n    }\n    case \"-\": {\n      operational = \"-\";\n      break;\n    }\n    case \"x\": {\n      operational = \"x\";\n      break;\n    }\n    case \"÷\": {\n      operational = \"÷\";\n      break;\n    }\n    case \"=\": {\n      // 先将两次数字转型\n      var num1 = parseFloat(number1);\n      var num2 = parseFloat(number2);\n      switch (operational) {\n        case \"+\":\n          lable.innerHTML = num1 + num2;\n          break;\n        case \"-\":\n          lable.innerHTML = num1 - num2;\n          break;\n        case \"x\":\n          lable.innerHTML = num1 * num2;\n          break;\n        case \"÷\":\n          if (num2 === 0) {\n            lable.innerHTML = \"错误\";\n          } else {\n            lable.innerHTML = num1 / num2;\n          }\n          break;\n        default:\n          break;\n      }\n      break;\n    }\