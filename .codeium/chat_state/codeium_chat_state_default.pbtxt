  // HttpServletRequest http协议的请求对象，包含客户端发来的信息以及提交的数据\n    // HttpServletResponse http协议的响应对象，返回客户端的信息以及数据\n    // 设置编码\n    req.setCharacterEncoding(\"utf-8\");\n    resp.setCharacterEncoding(\"utf-8\");\n    resp.setContentType(\"text/html;charset=utf-8\");\n    // 利用输出数据的对象，将转为json数据字符串输出到前端\n    PrintWriter printWriter = resp.getWriter();\n\n    // 接受前端的请求：action(登录、注册)\n    String action = req.getParameter(\"action\");\n    // 判断这个指令和请求\n    switch (action) {\n        case \"login\":\n            break;\n        case \"register\":\n            break;\n        default:\n            System.out.println(\"啥也不是\");\n    }\n}" node_name:"doPost" params:"(HttpServletRequest req, HttpServletResponse resp)" definition_line:21 start_line:21 end_line:44 start_col:4 end_col:5 leading_whitespace:"    " language:LANGUAGE_JAVA} language:LANGUAGE_JAVA file_path:"/home/lxw/Desktop/千锋教育/Java/day03_web/src/main/java/com/qfedu/make/controller/UserController.java"}}}} messages:{message:{message_id:"status-96263d19-97b8-4755-9102-b2ebc25c448d" source:CHAT_MESSAGE_SOURCE_SYSTEM timestamp:{seconds:1700717705 nanos:466958701} conversation_id:"X1K6GxtujCGWo3qj2tEtUxgEUnlRnEDL" status:{context_relevancy:{is_loading:true}}} stream_id:"a8b7b68a-4d49-4558-9ba5-0cdc63519ce4"} messages:{message:{message_id:"bot-b6f1092d-9aea-4ba7-80f9-bd61b3c5c96a" source:CHAT_MESSAGE_SOURCE_SYSTEM timestamp:{seconds:1700717706 nanos:716778988} conversation_id:"X1K6GxtujCGWo3qj2tEtUxgEUnlRnEDL" action:{edit:{file_path:"/home/lxw/Desktop/千锋教育/Java/day03_web/src/main/java/com/qfedu/make/controller/UserController.java" diff:{start_line:21 end_line:21 unified_diff:{lines:{text:"    /**" type:UNIFIED_DIFF_LINE_TYPE_INSERT} lines:{text:"     * 实现登录的功能" type:UNIFIED_DIFF_LINE_TYPE_INSERT} lines:{text:"     *" type:UNIFIED_DIFF_LINE_TYPE_INSERT} lines:{text:"     * @param  req   HttpServletRequest http协议的请求对象，包含客户端发来的信息以及提交的数据" type:UNIFIED_DIFF_LINE_TYPE_INSERT} lines:{text:"     * @param  resp  HttpServletResponse 