"+\": {\n      operational = \"+\";\n      break;\n    }\n    case \"-\": {\n      operational = \"-\";\n      break;\n    }\n    case \"x\": {\n      operational = \"x\";\n      break;\n    }\n    case \"÷\": {\n      operational = \"÷\";\n      break;\n    }\n    case \"=\": {\n      // 先将两次数字转型\n      var num1 = parseFloat(number1);\n      var num2 = parseFloat(number2);\n      switch (operational) {\n        case \"+\":\n          lable.innerHTML = num1 + num2;\n          break;\n        case \"-\":\n          lable.innerHTML = num1 - num2;\n          break;\n        case \"x\":\n          lable.innerHTML = num1 * num2;\n          break;\n        case \"÷\":\n          if (num2 === 0) {\n            lable.innerHTML = \"错误\";\n          } else {\n            lable.innerHTML = num1 / num2;\n          }\n          break;\n        default:\n          break;\n      }\n      break;\n    }\n    default: {\n      if (operational === \"\") {\n        number1 += txt;\n        lable.innerHTML = number1;\n      } else {\n        number2 += txt;\n        lable.innerHTML = number2;\n      }\n      break;\n    }\n  }\n};" clean_function:"btns[i].onclick = function () {\n  var txt = this.innerHTML;\n  console.log(this.innerHTML);\n  // console.log(txt);\n  // console.log(typeof txt);\n  switch (txt) {\n    case \"AC\": {\n      // 清除为0\n      number1 = \"\";\n      number2 = \"\";\n      operational = \"\";\n      lable.innerHTML = \"0\";\n      break;\n    }\n    case \"+/-\": {\n      if (operational === \"\") {\n        lable.innerHTML = \"-\" + number1;\n        number1 = number1 * -1;\n      } else {\n        lable.innerHTML = \"-\" + number2;\n        number2 = number2 * -1;\n      }\n      break;\n    }\n    case \"%\": {\n      // 啥乱苹果\n      // A% + B% = A% + A% * B%\n      if (operational === \"\") {\n        number1 = number1 / 100;\n        lable.innerHTML = number1;\n      } else if (operational === \"+\" || operational === \"-\") {\n        number2 = number1 * (nu