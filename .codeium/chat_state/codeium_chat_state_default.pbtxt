     // 清除为0\n       number1 = \"\";\n       number2 = \"\";\n       operational = \"\";\n       lable.innerHTML = \"0\";\n       break;\n     }\n     case \"+/-\": {\n       if (operational === \"\") {\n         lable.innerHTML = \"-\" + number1;\n-        number1 = number1 * -1;\n+        number1 = -number1;\n       } else {\n         lable.innerHTML = \"-\" + number2;\n-        number2 = number2 * -1;\n+        number2 = -number2;\n       }\n       break;\n     }\n     case \"%\": {\n-      // 啥乱苹果\n-      // A% + B% = A% + A% * B%\n       if (operational === \"\") {\n         number1 = number1 / 100;\n         lable.innerHTML = number1;\n       } else if (operational === \"+\" || operational === \"-\") {\n         number2 = number1 * (number2 / 100);\n         lable.innerHTML = number2;\n       } else {\n         number2 = number2 / 100;\n         lable.innerHTML = number2;\n       }\n       break;\n     }\n     case \"+\": {\n       operational = \"+\";\n       break;\n     }\n     case \"-\": {\n       operational = \"-\";\n       break;\n     }\n     case \"x\": {\n       operational = \"x\";\n       break;\n     }\n     case \"÷\": {\n       operational = \"÷\";\n       break;\n     }\n     case \"=\": {\n-      // 先将两次数字转型\n       var num1 = parseFloat(number1);\n       var num2 = parseFloat(number2);\n       switch (operational) {\n         case \"+\":\n           lable.innerHTML = num1 + num2;\n           break;\n         case \"-\":\n           lable.innerHTML = num1 - num2;\n           break;\n         case \"x\":\n           lable.innerHTML = num1 * num2;\n           break;\n         case \"÷\":\n           if (num2 === 0) {\n             lable.innerHTML = \"错误\";\n           } else {\n             lable.innerHTML = num1 / num2;\n           }\n           break;\n         default:\n           break;\n       }\n       break;\n     }\n     default: {\n       if (operational === \"\") {\n         number1 += txt;\n         lable.innerHTML = number1;\n       } else {\n         number2 += txt;\n         lable.innerHTML = number2;\n       }\n       break;\n     }\n   }\n-};\n+});\n```\n\n我将 `onclick` 事件替换为 `addEventListener`，将点击事件附加到按钮上。这样可以确保可以将多个事件侦听器附加到同一个按钮上，而不会互相覆盖。"} num_tokens:685}} stream_id:"8d903ac6-7645-4973-99ff-02e691ddf71f"} user_settings:{}